VITE_API_URL=https://api.example.com

# Speculos dev mode — set this to enable SpeculosTransport instead of WebUSB
# Start the bridge first: npm run speculos:bridge
# VITE_SPECULOS_BRIDGE_URL=http://127.0.0.1:7777
VITE_MINASCAN_MAINNET_BASE_URL=https://minascan.io/mainnet
VITE_MINASCAN_DEVNET_BASE_URL=https://minascan.io/devnet
VITE_MINAEXPLORER_MAINNET_BASE_URL=https://minaexplorer.com
VITE_MINAEXPLORER_DEVNET_BASE_URL=https://devnet.minaexplorer.com

# ─── Virtual USB device (WebUSB mock for Speculos) ────────────────────────────
# Set VITE_WEBUSB_MOCK=true to replace navigator.usb with a virtual Ledger
# device that forwards all USB traffic to the Speculos bridge.
# This allows TransportWebUSB (the production code path) to work unchanged
# against Speculos without any custom transport class.
#
# Both vars must be set together to activate the mock:
#   VITE_SPECULOS_BRIDGE_URL=http://127.0.0.1:7777
#   VITE_WEBUSB_MOCK=true
#
# Start the bridge (which now includes the virtual USB endpoints):
#   npm run speculos:bridge
# Or with verbose USB logs:
#   node scripts/speculos-bridge.mjs --verbose
# VITE_WEBUSB_MOCK=true
